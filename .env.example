# AI COUNCIL — 環境変数テンプレート
# 使い方: このファイルを `.env` にコピーし、必要な行だけ値を入れる（.env は .gitignore 済み・コミットしない）。
# どれも未設定なら API は自動で MockLLMClient にフォールバックし、キー無し・ゼロコストで動く。

# ───────────────────────────────────────────────────────────
# ローカル/個人運用（自分のキーで本物の LLM を使う）
# ───────────────────────────────────────────────────────────
# Anthropic のキーを入れると実 LLM で討論する。空なら Mock。
# 注意: プロデューサは「誰も見ていなくても完走」する設計のため、開始後に画面を閉じてもコストが出る。
ANTHROPIC_API_KEY=

# 既定モデル（未指定なら claude-opus-4-8）。コスト優先なら claude-sonnet-4-6 等に。
# AI_TEAMS_MODEL=claude-opus-4-8

# 1 発言あたりの最大トークン（既定 2048）。発言が文中で切れるなら上げる（コスト増）。
# AI_TEAMS_MAX_TOKENS=2048
# 議事録(統合)の最大トークン。
# AI_TEAMS_SYNTHESIS_MAX_TOKENS=4096
# Mock 応答のチャンク毎ディレイ秒（既定 0）。実 LLM 無しでストリーミングのライブ感を見たいとき 0.2 等。
# AI_TEAMS_MOCK_DELAY=0

# ───────────────────────────────────────────────────────────
# 共有/公開運用（BYOK = 各自が自分のキーを持参）— 公開時の推奨セット
# ───────────────────────────────────────────────────────────
# 1 で「サーバのキーを来訪者に一切使わせない」。来訪者は自分のキーを画面入力し、毎リクエストの
# ヘッダで送る（ブラウザ localStorage のみ・サーバ非保存）。キー未入力なら自動で Mock。
# AI_TEAMS_BYOK=1
# 1 でペルソナ/プリセットの作成・更新・削除を 403（来訪者にサーバ上のファイルを触らせない）。
# AI_TEAMS_READONLY=1
# 設定すると全リクエストに Bearer トークンを要求（アクセス自体のゲート）。空 = 開放。
# AI_TEAMS_API_TOKEN=
# CORS 許可オリジン（カンマ区切り）。未設定なら http://localhost:3000。
# AI_TEAMS_ALLOWED_ORIGINS=https://example.com
# レート制限（IP 毎・固定窓）。
# AI_TEAMS_RATE_MAX=20
# AI_TEAMS_RATE_WINDOW=60
# 進行中セッションの同時上限（paused 無期限残留による DoS 抑止）。
# AI_TEAMS_MAX_ACTIVE=12
# リバースプロキシ(CDN/トンネル)越しに実 IP を信頼するか（既定 1）。直接公開なら 0。
# AI_TEAMS_TRUST_PROXY_IP=1
# 議場開放(入力待ち)の自動クローズ秒。
# AI_TEAMS_FLOOR_IDLE_TIMEOUT=900
# Web 検索(調査役)の 1 セッション当たり呼び出し上限。
# AI_TEAMS_RESEARCH_CAP=4

# ───────────────────────────────────────────────────────────
# 内製/オープンモデル（OpenAI 互換エンドポイントを base_url で叩く: OpenRouter / Ollama 等）
# ───────────────────────────────────────────────────────────
# 例: OpenRouter なら https://openrouter.ai/api/v1
# AI_TEAMS_LOCAL_BASE_URL=
# AI_TEAMS_LOCAL_MODEL=
# AI_TEAMS_LOCAL_API_KEY=
# Web 検索の手段（例: openrouter）。空なら検索なし。
# AI_TEAMS_LOCAL_SEARCH=
# 討論モード(モデル×長さ)プリセットの定義（任意）。
# AI_TEAMS_LOCAL_PRESETS=
# 1 で、来訪者の選択に関わらず全実 LLM を上記 local に固定（キー不要で実 LLM 運用）。
# AI_TEAMS_FORCE_LOCAL=1

# ───────────────────────────────────────────────────────────
# フロントエンド（web/.env.local に置く・ビルド時に埋め込まれる）
# ───────────────────────────────────────────────────────────
# API のベース URL。空＝相対パス＝同一オリジン配信。開発時は http://localhost:8000。
# NEXT_PUBLIC_API_BASE=
